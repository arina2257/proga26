      "source": [
        "# Задание task_02_09.\n",
        "# Задание: Дано вещественное число a. Найдите наименьшее натуральное n, для которого верно\n",
        "# Выполнила: Ермакова Арина Сергеевна\n",
        "# Группа: ЦИБ-251\n",
        "\n",
        "a = float(input())\n",
        "sum_harmonic = 0\n",
        "n = 0\n",
        "\n",
        "while sum_harmonic <= a:\n",
        "    n += 1\n",
        "    sum_harmonic += 1/n\n",
        "\n",
        "print(n)"
      ]
    }
